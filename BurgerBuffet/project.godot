; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Burger Buffet"
run/main_scene="res://Scenes/main_scene.tscn"
config/features=PackedStringArray("4.2", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GlobalSignals="*res://Scripts/Other/GlobalSignals.cs"
IngredientInventory="*res://Scripts/Other/IngredientInventory.cs"
OrderManager="*res://Scripts/Managers/OrderManager.cs"
GlobalResources="*res://Scenes/global_resources.tscn"
BoardManager="*res://Scripts/Managers/BoardManager.cs"
AudioManager="*res://Scenes/audio_manager.tscn"

[display]

window/size/viewport_width=1024
window/size/viewport_height=576
window/stretch/mode="viewport"
window/stretch/scale=2.0

[dotnet]

project/assembly_name="Burger Buffet"

[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_2="Items"
2d_physics/layer_3="Enemies"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
